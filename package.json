{
  "name": "eu-climate-data-hub",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "fetch:worldbank": "node scripts/fetchWorldBank.js",
    "process:data": "node scripts/processData.js",
    "start": "ts-node -r tsconfig-paths/register src/index.ts",
    "metrics": "ts-node -r tsconfig-paths/register scripts/jobs/updateAllMetrics.ts",
    "ingest": "ts-node -r tsconfig-paths/register ./scripts/jobs/runWorldBankIngestion.ts",
    "build": "tsc",
    "start:prod": "node dist/index.js",
    "test": "NODE_ENV=test jest"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@app/(.*)$": "<rootDir>/src/app/$1",
      "^@config/(.*)$": "<rootDir>/src/config/$1",
      "^@errors/(.*)$": "<rootDir>/src/modules/shared/errors/$1",
      "^@middleware/(.*)$": "<rootDir>/src/modules/shared/middleware/$1",
      "^@utils/(.*)$": "<rootDir>/src/modules/shared/utils/$1",
      "^@db/(.*)$": "<rootDir>/src/modules/infrastructure/database/$1",
      "^@ai/(.*)$": "<rootDir>/src/modules/infrastructure/ai/$1",
      "^@pipelines/(.*)$": "<rootDir>/src/modules/climate/pipelines/$1"
    },
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.test.json"
      }
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "node-fetch": "^2.7.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
