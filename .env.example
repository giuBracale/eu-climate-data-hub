# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/climate"

# TCP port the API listens on (default: 3000)
PORT=3000

# Node environment — controls log format
# "production" → structured JSON  |  anything else → pretty-printed
NODE_ENV="development"

# CORS allowed origins (comma-separated, no spaces)
# Default when unset: http://localhost:5173 (Vite dev server)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:3000"

# Base URL of the AI insights service
# Local dev: http://localhost:8000
# Docker:    http://ai-processor:8000
AI_SERVICE_URL="http://localhost:8000"

# Base URL shown in the Swagger UI "Servers" dropdown
# Local dev: http://localhost:3000/api
# Docker:    http://localhost:3001/api
SWAGGER_SERVER_URL="http://localhost:3000/api"
