/// <reference types="node" />
{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File Layout
    "rootDir": ".",
    "outDir": "./dist",

    // Environment Settings
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "types": ["node", "jest"],

    // Other Outputs
    "sourceMap": true,
    "declaration": false,
    "declarationMap": false,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Recommended Options
    "strict": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,

    // MIGRAZIONE GRADUALE
    "allowJs": true,
    "checkJs": false,
    "ignoreDeprecations": "6.0",

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],

      "@app/*": ["src/app/*"],
      "@config/*": ["src/config/*"],
      "@docs/*": ["src/docs/*"],

      "@errors/*": ["src/modules/shared/errors/*"],
      "@middleware/*": ["src/modules/shared/middleware/*"],
      "@utils/*": ["src/modules/shared/utils/*"],

      "@db/*": ["src/modules/infrastructure/database/*"],
      "@ai/*": ["src/modules/infrastructure/ai/*"],
      "@worldbank/*": ["src/modules/infrastructure/worldbank/*"],

      "@pipelines/*": ["src/modules/climate/pipelines/*"],

      "@generated/*": ["src/generated/*"]
    }
  },
  "include": ["src", "scripts", "tests"],
  "exclude": ["node_modules", "dist"]
}