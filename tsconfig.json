/// <reference types="node" />
{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File Layout
    "rootDir": ".",
    "outDir": "./dist",

    // Environment Settings
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "types": ["node", "jest"],

    // Other Outputs
    "sourceMap": true,
    "declaration": false,
    "declarationMap": false,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Recommended Options
    "strict": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,

    // MIGRAZIONE GRADUALE
    "allowJs": true,
    "checkJs": false,
    "ignoreDeprecations": "6.0",

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],

      "@api/*": ["src/modules/climate/api/*"],
      "@controllers/*": ["src/modules/climate/api/controllers/*"],
      "@routes/*": ["src/modules/climate/api/routes/*"],
      "@middleware/*": ["src/modules/shared/middleware/*"],
      "@validators/*": ["src/modules/climate/api/validators/*"],
      "@dto/*": ["src/modules/climate/api/dto/*"],

      "@app/*": ["src/app/*"],
      "@config/*": ["src/config/*"],
      "@docs/*": ["src/docs/*"],

      "@domain/*": ["src/domain/*"],
      "@services/*": ["src/domain/services/*"],
      "@errors/*": ["src/modules/shared/errors/*"],

      "@generated/*": ["src/generated/*"],

      "@infra/*": ["src/modules/infrastructure/*"],
      "@db/*": ["src/modules/infrastructure/database/*"],
      "@ai/*": ["src/modules/infrastructure/ai/*"],
      "@worldbank/*": ["src/modules/infrastructure/worldbank/*"],

      "@pipelines/*": ["src/modules/climate/pipelines/*"],
      "@processing/*": ["src/modules/climate/processing/*"],

      "@storage/*": ["src/storage/*"],

      "@utils/*": ["src/modules/shared/utils/*"]
    }
  },
  "include": ["src", "scripts", "tests"],
  "exclude": ["node_modules", "dist"]
}