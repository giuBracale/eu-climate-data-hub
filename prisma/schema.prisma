generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ClimateData {
  id         Int      @id @default(autoincrement())
  country    String
  year       Int
  gdp        Float?
  population Float?
  co2        Float?

  @@unique([country, year])
}