generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ClimateData {
  id         Int      @id @default(autoincrement())
  country    String
  year       Int
  gdp        Float?
  population Float?
  co2        Float?

  @@unique([country, year])
}

model ClimateMetrics {
  country                  String   @id

  co2_change_pct           Float?
  gdp_growth_pct           Float?
  population_growth_pct    Float?

  dataset_hash             String?

  updated_at               DateTime @default(now())

  data_points Int?
  first_year  Int?
  last_year   Int?

  @@map("climate_metrics")
}